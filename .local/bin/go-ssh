#!/bin/bash

function go-ssh () {
local selected_line=$(cat ~/.local/src/datagrip/hosts | walker -d --theme=theme-wide -p "Host:")

  if [ -n "$selected_line" ]; then
        if [[ "$selected_line" == *">"* ]]; then
            selected_host="${selected_line#*>}"
            # Убираем возможные пробелы в начале
            selected_host="${selected_host## }"
        else
            # Если разделитель не найден, используем всю строку
            selected_host="$selected_line"
        fi

    omarchy-launch-terminal bash -c "${selected_host}"
  fi
}

go-ssh

#!/bin/bash

OS="$(uname -s)"

if [[ "${OS}" == "Linux"* ]]; then

  kbd="$(hyprctl devices -j | jq -r '.keyboards | .[] | select(.main == true) | .name' | head -n1)"

  hyprctl -q switchxkblayout "$kbd" 0

elif [[ "${OS}" == "Darwin"* ]]; then

  CURRENT_LAYOUT=$(im-select)

  [[ $CURRENT_LAYOUT == "com.apple.keylayout.Russian" ]] && im-select com.apple.keylayout.US

fi

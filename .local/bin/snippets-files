#!/bin/bash

lock_file="${XDG_RUNTIME_DIR:-/tmp}/snippets-files.lock"

if [[ -f "${lock_file}" ]] && kill -0 "$(<"${lock_file}")" 2>/dev/null; then
  omarchy-menu close
  exit 0
fi

echo $$ > "${lock_file}"
trap 'rm -f "${lock_file}"' EXIT

hypr-switch-en

base_dir="$HOME/.local/src/datagrip"

selection="$(fd . --type f --follow "${base_dir}" \
  | sed -En "s#^${base_dir}/##p" \
  | omarchy-menu-select "File" -- --width 1792 --height 720)"

[[ -n "${selection}" ]] || exit 0

content="$(cat "${base_dir}/${selection}")"
printf '%s' "${content}" | wl-copy -n

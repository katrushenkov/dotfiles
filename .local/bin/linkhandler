#!/bin/sh

#!/bin/bash

OS="$(uname -s)"

if [[ "${OS}" == "Linux"* ]]; then

  hypr-switch-en

  if [ -z "$1" ]; then
  	url="$(wl-paste --primary)"
  else
  	url="$1"
  fi
 
  case "$url" in
  	*mkv|*webm|*mp4|*youtube.com/watch*|*youtube.com/playlist*|*youtube.com/shorts*|*youtu.be*|*hooktube.com*|*bitchute.com*|*videos.lukesmith.xyz*|*odysee.com*)
      selection=$(omarchy-menu-select "Action…" "yta-opus" "ytv-360" "mpv") || exit 0

     case "$selection" in
      "yta-opus"|"ytv-360")
        bmdirs="${XDG_CONFIG_HOME:-$HOME/.config}/shell/bm-dirs"
        dir_options=$(eval "echo \"$(cat "$bmdirs" 2>/dev/null)\"" | awk '
          !/^[[:space:]]*#/ && !/^[[:space:]]*$/ {
            line=$0
            sub(/[[:space:]]*#.*$/,"",line)
            match(line, /^[^[:space:]]+/)
            key=substr(line,RSTART,RLENGTH)
            path=substr(line,RLENGTH+1)
            gsub(/^[[:space:]]+/,"",path)
            if (path != "") print key" -> "path
          }')

        if [ -n "$dir_options" ]; then
          dir_selection=$(printf '%s\n' "$dir_options" | omarchy-menu-select "Download to…") || exit 0
          download_dir="${dir_selection#* -> }"
        else
          download_dir="$HOME"
        fi

        case "$selection" in
         "yta-opus") omarchy-launch-terminal yt-dlp -c --extract-audio --audio-format opus --output "%(title)s.%(ext)s" -P "$download_dir" "$url" ;;
         "ytv-360") omarchy-launch-terminal yt-dlp -c -f 18 --output "%(title)s.%(ext)s" -P "$download_dir" "$url" ;;
        esac ;;
      "mpv") setsid -f mpv -quiet "$url" >/dev/null 2>&1 ;;
     esac ;;
  	*png|*jpg|*jpe|*jpeg|*gif|*webp)
  		curl -sL "$url" > "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")" && imv -f "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")"  >/dev/null 2>&1 & ;;
  	*pdf|*cbz|*cbr)
  		curl -sL "$url" > "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")" && zathura "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")"  >/dev/null 2>&1 & ;;
  	*mp3|*flac|*opus|*mp3?source*)
  		setsid -f mpv -quiet "$url" >/dev/null 2>&1 ;;
  	*)
  		[ -f "$url" ] && setsid -f "$TERMINAL" -e "$EDITOR" "$url" >/dev/null 2>&1 || setsid -f "$BROWSER" "$url" >/dev/null 2>&1
  esac

elif [[ "${OS}" == "Darwin"* ]]; then

  previous_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')

  /opt/homebrew/bin/rg -v '^#' ~/.local/src/datagrip/snippets | grep -v "^$" | $HOME/.local/bin/dmenu-raycast | awk -F ' #' '{printf "%s", $1}' | pbcopy -

  # Возвращаем фокус к предыдущему приложению
  osascript <<EOF
  tell application "$previous_app"
      activate
  end tell
  tell application "System Events"
              keystroke "v" using command down
  end tell
EOF

fi


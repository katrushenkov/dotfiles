#!/bin/sh

#!/bin/bash

OS="$(uname -s)"

LAUNCHER="walker --dmenu --height 600 --minheight 600 --maxheight 600 --width 1200"

if [[ "${OS}" == "Linux"* ]]; then

  hypr-switch-en

  if [ -z "$1" ]; then
  	url="$(wl-paste --primary)"
  else
  	url="$1"
  fi
 
  case "$url" in
  	*mkv|*webm|*mp4|*youtube.com/watch*|*youtube.com/playlist*|*youtube.com/shorts*|*youtu.be*|*hooktube.com*|*bitchute.com*|*videos.lukesmith.xyz*|*odysee.com*)
      [ -f "$XDG_DATA_HOME/cookies.txt" ] || ( notify-send "You need to extract cookies for yt-dlp" "File cookies.txt not found \n Use Get cookies.txt LOCALLY for browser" && exit 0 )
      selection=$(echo -e "\
      yta-opus
      ytv-360
      mpv" | omarchy-launch-walker --dmenu --width 1195 --minheight 1 --maxheight 600 -p "Action…" 2>/dev/null)
     [[ -z "$selection" ]] && exit 0

     case "$selection" in
      "yta-opus") omarchy-launch-terminal yt-dlp -c --extract-audio --audio-format opus --output "%(title)s.%(ext)s" --cookies $XDG_DATA_HOME/cookies.txt -P $HOME "$url" ;;
      "ytv-360") omarchy-launch-terminal yt-dlp -c -f 18 --output "%(title)s.%(ext)s" --cookies $XDG_DATA_HOME/cookies.txt -P $HOME "$url" ;;
      "mpv") setsid -f mpv -quiet "$url" >/dev/null 2>&1 ;;
     esac ;;
  	*png|*jpg|*jpe|*jpeg|*gif|*webp)
  		curl -sL "$url" > "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")" && imv -f "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")"  >/dev/null 2>&1 & ;;
  	*pdf|*cbz|*cbr)
  		curl -sL "$url" > "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")" && zathura "/tmp/$(echo "$url" | sed "s/.*\///;s/%20/ /g")"  >/dev/null 2>&1 & ;;
  	*mp3|*flac|*opus|*mp3?source*)
  		setsid -f mpv -quiet "$url" >/dev/null 2>&1 ;;
  	*)
  		[ -f "$url" ] && setsid -f "$TERMINAL" -e "$EDITOR" "$url" >/dev/null 2>&1 || setsid -f "$BROWSER" "$url" >/dev/null 2>&1
  esac
      #wtype "$(grep -v "^$" ~/.local/src/datagrip/snippets | $LAUNCHER | awk -F ' #' '{print $1}' )"

elif [[ "${OS}" == "Darwin"* ]]; then

  previous_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')

  /opt/homebrew/bin/rg -v '^#' ~/.local/src/datagrip/snippets | grep -v "^$" | $HOME/.local/bin/dmenu-raycast | awk -F ' #' '{printf "%s", $1}' | pbcopy -

  # Возвращаем фокус к предыдущему приложению
  osascript <<EOF
  tell application "$previous_app"
      activate
  end tell
  tell application "System Events"
              keystroke "v" using command down
  end tell
EOF

fi


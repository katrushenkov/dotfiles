#!/bin/bash

lock_file="${XDG_RUNTIME_DIR:-/tmp}/datagrip-go.lock"

if [[ -f "${lock_file}" ]] && kill -0 "$(<"${lock_file}")" 2>/dev/null; then
  omarchy-menu close
  exit 0
fi

echo $$ > "${lock_file}"
trap 'rm -f "${lock_file}"' EXIT

hypr-switch-en

datagrip_dir="$HOME/.local/src/datagrip"
anima_dir="$HOME/.local/src/anima"

# omarchy-menu-select passes the whole option list as a single exec argument,
# which hits Linux's per-argument size limit (128K) once the tree gets large.
# These directories are too big to flatten recursively; keep them as a single
# entry each and let nnn handle browsing inside them.
skip_dirs=(2ch-scripts unnecessary sc tips flant)

fd_exclude_args=()
for d in "${skip_dirs[@]}"; do
  fd_exclude_args+=(--exclude "${d}")
done

list_entries() {
  local base="$1"
  fd . --follow "${fd_exclude_args[@]}" "${base}" | sed -En "s#^${base}/##p"
  for d in "${skip_dirs[@]}"; do
    [[ -d "${base}/${d}" ]] && echo "${d}"
  done
}

selection="$(
  { list_entries "${datagrip_dir}"; list_entries "${anima_dir}"; } \
    | sort -u \
    | while read -r item; do
        if [[ -d "${datagrip_dir}/${item}" || -d "${anima_dir}/${item}" ]]; then
          echo "📁 ${item}/"
        else
          echo "📄 ${item}"
        fi
      done \
    | omarchy-menu-select "Go" -- --width 1792 --height 720
)"

[[ -n "${selection}" ]] || exit 0

item="$(sed -E 's/^[^ ]* //; s/\/$//' <<< "${selection}")"

if [[ -d "${datagrip_dir}/${item}" ]]; then
  omarchy launch terminal nnn "${datagrip_dir}/${item}"
elif [[ -d "${anima_dir}/${item}" ]]; then
  omarchy launch terminal nnn "${anima_dir}/${item}"
elif [[ -f "${datagrip_dir}/${item}" ]]; then
  omarchy launch terminal nvim "${datagrip_dir}/${item}"
else
  omarchy launch terminal nvim "${anima_dir}/${item}"
fi
